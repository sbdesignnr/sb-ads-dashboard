// SB Design — Ads Analytics Dashboard
// Local development uses SQLite. To migrate to PostgreSQL later, change the
// datasource provider to "postgresql" and update DATABASE_URL.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String
  role         String   @default("admin")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// --- Competitor Intelligence ---

model Competitor {
  id          String           @id @default(cuid())
  name        String
  url         String
  lastScanned DateTime?
  isActive    Boolean          @default(true)
  createdAt   DateTime         @default(now())
  scans       CompetitorScan[]
}

model CompetitorScan {
  id           String     @id @default(cuid())
  competitorId String
  competitor   Competitor @relation(fields: [competitorId], references: [id], onDelete: Cascade)
  scannedAt    DateTime   @default(now())
  services     Json?
  pricing      Json?
  blogPosts    Json?
  techStack    Json?
  aiAnalysis   String?
  changes      Json?
  rawContent   String?

  @@index([competitorId, scannedAt])
}

model AiChatHistory {
  id        String   @id @default(cuid())
  title     String
  messages  Json // [{ role: "user"|"assistant", content: string, imageCount?: number }]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("ai_chat_history")
}

model BlogPost {
  id              String    @id @default(cuid())
  title           String    @default("")
  slug            String    @unique
  content         String    @default("") // Markdown
  metaTitle       String?   @map("meta_title")
  metaDescription String?   @map("meta_description")
  imageUrl        String?   @map("image_url")
  imageAlt        String?   @map("image_alt")
  status          String    @default("draft") // draft | published
  category        String?
  targetKeyword   String?   @map("target_keyword")
  seoScore        Int       @default(0) @map("seo_score")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  publishedAt     DateTime? @map("published_at")

  @@index([status, publishedAt])
  @@map("blog_posts")
}

model LeadSegment {
  id                 String        @id @default(cuid())
  name               String
  color              String        @default("#3b82f6")
  icon               String?
  keywords           String[]      @default([])
  communicationStyle String?       @map("communication_style")
  scanOffset         Int           @default(0) @map("scan_offset") // rotating region-window cursor
  lastScanRegions    String[]      @default([]) @map("last_scan_regions") // regions covered by the last scan
  createdAt          DateTime      @default(now()) @map("created_at")
  leads              Lead[]
  scanJobs           LeadScanJob[]

  @@map("lead_segments")
}

model Lead {
  id                String       @id @default(cuid())
  segmentId         String?      @map("segment_id")
  segment           LeadSegment? @relation(fields: [segmentId], references: [id], onDelete: SetNull)
  emails            LeadEmail[]
  companyName       String       @map("company_name")
  ico               String?
  websiteUrl        String?      @unique @map("website_url")
  websiteScore      Int?         @map("website_score") // total 0-100, higher = worse (better lead)
  technicalScore    Int?         @map("technical_score") // 0-40
  visualScore       Int?         @map("visual_score") // 0-60 (AI visual outdatedness)
  websiteAge        Int?         @map("website_age")
  copyrightYear     Int?         @map("copyright_year")
  websiteTechnology String?      @map("website_technology")
  hasModernFramework Boolean?    @map("has_modern_framework")
  pageSpeedMobile   Int?         @map("page_speed_mobile")
  pageSpeedDesktop  Int?         @map("page_speed_desktop")
  hasSsl            Boolean?     @map("has_ssl")
  isMobileFriendly  Boolean?     @map("is_mobile_friendly")
  websiteIssues     String[]     @map("website_issues")
  visualIssues      String[]     @default([]) @map("visual_issues") // AI-detected visual problems
  aiVisualReason    String?      @map("ai_visual_reason") // why the design looks outdated
  disqualifyReason  String?      @map("disqualify_reason") // set when a lead is filtered out
  aiSummary         String?      @map("ai_summary")
  aiPainPoint       String?      @map("ai_pain_point")
  aiOpportunity     String?      @map("ai_opportunity")
  aiOutreachAngle   String?      @map("ai_outreach_angle")
  bestContactTime   String?      @map("best_contact_time")
  companyActive     Boolean?     @map("company_active")
  ownerName         String?      @map("owner_name")
  ownerPosition     String?      @map("owner_position")
  companyEmail      String?      @map("company_email")
  companyPhone      String?      @map("company_phone")
  companyAddress    String?      @map("company_address")
  companyCity       String?      @map("company_city")
  status            String       @default("new") // new | contacted | rejected | converted
  notes             String?
  source            String?
  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt         DateTime     @updatedAt @map("updated_at")
  lastScannedAt     DateTime?    @map("last_scanned_at")

  @@index([segmentId, status])
  @@map("leads")
}

// One outreach e-mail (initial or follow-up) for a lead.
model LeadEmail {
  id             String    @id @default(cuid())
  leadId         String    @map("lead_id")
  lead           Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  subject        String
  body           String    @db.Text
  emailType      String    @map("email_type") // initial | followup1 | followup2
  status         String    @default("draft") // draft | approved | sent | failed | rejected
  scheduledAt    DateTime? @map("scheduled_at")
  sentAt         DateTime? @map("sent_at")
  openedAt       DateTime? @map("opened_at") // first open
  lastOpenedAt   DateTime? @map("last_opened_at")
  openCount      Int       @default(0) @map("open_count")
  openLog        Json?     @map("open_log") // [{ts, ip, ua}] capped
  clickedAt      DateTime? @map("clicked_at") // first click on a tracked link
  lastClickedAt  DateTime? @map("last_clicked_at")
  clickCount     Int       @default(0) @map("click_count")
  repliedAt      DateTime? @map("replied_at")
  brevoMessageId String?   @map("brevo_message_id")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@index([status, scheduledAt])
  @@index([leadId])
  @@index([brevoMessageId])
  @@map("lead_emails")
}

// A sending campaign scoped to a segment, with a daily cap + send time.
model LeadCampaign {
  id           String    @id @default(cuid())
  name         String
  segmentId    String?   @map("segment_id")
  dailyLimit   Int       @default(20) @map("daily_limit")
  sendTime     String    @default("08:30") @map("send_time")
  isActive     Boolean   @default(false) @map("is_active")
  totalSent    Int       @default(0) @map("total_sent")
  totalOpened  Int       @default(0) @map("total_opened")
  totalReplied Int       @default(0) @map("total_replied")
  startedAt    DateTime? @map("started_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  @@map("lead_campaigns")
}

model LeadScanJob {
  id             String       @id @default(cuid())
  segmentId      String?      @map("segment_id")
  segment        LeadSegment? @relation(fields: [segmentId], references: [id], onDelete: SetNull)
  status         String       @default("pending") // pending | running | completed | failed
  foundTotal     Int          @default(0) @map("found_total") // discovered + analyzed
  foundQualified Int          @default(0) @map("found_qualified")
  foundRejected  Int          @default(0) @map("found_rejected")
  regions        String[]     @default([]) @map("regions") // region names covered by this scan
  startedAt      DateTime?    @map("started_at")
  completedAt    DateTime?    @map("completed_at")
  errorMessage   String?      @map("error_message")
  createdAt      DateTime     @default(now()) @map("created_at")

  @@index([segmentId, createdAt])
  @@map("lead_scan_jobs")
}

// Singleton row (id = "primary") holding push-notification preferences.
model NotificationSetting {
  id                String   @id @default("primary")
  telegramChatId    String?  @map("telegram_chat_id")
  enabled           Boolean  @default(true)
  alertConversions  Boolean  @default(true) @map("alert_conversions")
  alertActions      Boolean  @default(true) @map("alert_actions")
  alertBlog         Boolean  @default(true) @map("alert_blog")
  blogReminderDay   Int      @default(1) @map("blog_reminder_day") // ISO weekday 1=Mon…7=Sun
  blogReminderHour  Int      @default(9) @map("blog_reminder_hour") // 0-23, Europe/Bratislava
  minConversionValue Float?  @map("min_conversion_value")
  quietHoursStart   Int?     @map("quiet_hours_start") // 0-23 local hour, inclusive
  quietHoursEnd     Int?     @map("quiet_hours_end")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@map("notification_settings")
}

// De-dupe log so the same alert isn't pushed repeatedly.
model SentAlert {
  id         String   @id @default(cuid())
  dedupKey   String   @unique @map("dedup_key")
  type       String
  severity   String
  campaignId String?  @map("campaign_id")
  title      String
  body       String
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@map("sent_alerts")
}

// Last-seen conversion totals per campaign, to detect new conversions.
model CampaignConvState {
  campaignId       String   @id @map("campaign_id")
  conversions      Float    @default(0)
  conversionsValue Float    @default(0) @map("conversions_value")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@map("campaign_conv_state")
}

model VideoCategory {
  id        String           @id @default(cuid())
  name      String
  color     String           @default("#3b82f6")
  order     Int              @default(0)
  createdAt DateTime         @default(now()) @map("created_at")
  channels  YoutubeChannel[]

  @@map("video_categories")
}

model YoutubeChannel {
  id               String         @id @default(cuid())
  channelId        String         @unique @map("channel_id")
  channelName      String         @map("channel_name")
  channelThumbnail String?        @map("channel_thumbnail")
  categoryId       String?        @map("category_id")
  category         VideoCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  addedAt          DateTime       @default(now()) @map("added_at")
  videos           YoutubeVideo[]

  @@map("youtube_channels")
}

model YoutubeVideo {
  id          String         @id @default(cuid())
  videoId     String         @unique @map("video_id")
  channelId   String         @map("channel_id")
  channel     YoutubeChannel @relation(fields: [channelId], references: [channelId], onDelete: Cascade)
  title       String
  thumbnail   String?
  publishedAt DateTime       @map("published_at")
  duration    String?
  watched     Boolean        @default(false)
  saved       Boolean        @default(false)
  createdAt   DateTime       @default(now()) @map("created_at")

  @@index([publishedAt])
  @@map("youtube_videos")
}

model CampaignReminder {
  id                 String   @id @default(cuid())
  recommendationText String   @map("recommendation_text")
  insightTitle       String?  @map("insight_title")
  priority           String?
  campaignId         String?  @map("campaign_id")
  campaignName       String?  @map("campaign_name")
  implementBy        DateTime @map("implement_by")
  checkResultsBy     DateTime @map("check_results_by")
  status             String   @default("pending") // pending | checked | dismissed
  baselineMetrics    Json?    @map("baseline_metrics")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@index([status, checkResultsBy])
  @@map("campaign_reminders")
}

model KeywordCache {
  id          String   @id @default(cuid())
  keyword     String   @unique
  volume      Int
  competition String
  cpc         Float
  updatedAt   DateTime @default(now())
}

model RegionalData {
  id                 String   @id @default(cuid())
  region             String   @unique
  avgSalary          Float
  gdpPerCapita       Float
  businessDensity    Float
  recommendedPricing Json
  updatedAt          DateTime @default(now())
}

// Stores the OAuth2 tokens for the connected Google Ads account.
// A single row is used (id = "primary").
model GoogleAdsToken {
  id           String    @id @default("primary")
  accessToken  String?
  refreshToken String
  expiresAt    DateTime?
  customerId   String?
  scope        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

// ── Finance module ──────────────────────────────────────────────────────────

model FinanceAccount {
  id           String               @id @default(cuid())
  name         String
  type         String               // personal | business
  currency     String               @default("EUR")
  createdAt    DateTime             @default(now()) @map("created_at")
  transactions FinanceTransaction[]

  @@map("finance_accounts")
}

model FinanceTransaction {
  id          String         @id @default(cuid())
  accountId   String         @map("account_id")
  account     FinanceAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  date        DateTime
  amount      Decimal        @db.Decimal(12, 2) // + income, - expense
  description String
  category    String
  subcategory String?
  type        String         // income | expense | transfer
  source      String         // csv_import | manual | voice
  notes       String?
  createdAt   DateTime       @default(now()) @map("created_at")

  @@index([accountId, date])
  @@index([date])
  @@map("finance_transactions")
}

model FinanceBudget {
  id           String   @id @default(cuid())
  category     String
  monthlyLimit Decimal  @map("monthly_limit") @db.Decimal(12, 2)
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("finance_budgets")
}

// Singleton (id = "primary") holding the public booking availability config.
model BookingSetting {
  id            String   @id @default("primary")
  availableDays Int[]    @default([1, 2, 3, 4, 5]) @map("available_days") // 1=Mon … 7=Sun
  startTime     String   @default("09:00") @map("start_time")
  endTime       String   @default("18:00") @map("end_time")
  duration      Int      @default(30) // minutes per slot
  bufferTime    Int      @default(30) @map("buffer_time") // minutes between calls
  minNotice     Int      @default(24) @map("min_notice") // hours before a booking
  timezone      String   @default("Europe/Bratislava")
  ownerEmail    String   @default("biben@sbdesign.sk") @map("owner_email")
  ownerName     String   @default("Samuel Bibeň") @map("owner_name")
  meetingTitle  String   @default("Online hovor - SB Design") @map("meeting_title")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("booking_settings")
}

model Booking {
  id             String   @id @default(cuid())
  date           DateTime // calendar day (UTC midnight)
  startTime      String   @map("start_time") // "10:00"
  endTime        String   @map("end_time") // "10:30"
  clientName     String   @map("client_name")
  clientEmail    String   @map("client_email")
  clientPhone    String?  @map("client_phone")
  clientCompany  String?  @map("client_company")
  message        String?
  status         String   @default("confirmed") // confirmed | cancelled
  googleMeetLink String?  @map("google_meet_link")
  reminderSent   Boolean  @default(false) @map("reminder_sent")
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([date, status])
  @@map("bookings")
}
